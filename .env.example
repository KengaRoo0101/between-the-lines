# Canonical production URL. Do not use localhost or a temporary Render URL for go-live.
PUBLIC_URL=https://www.lrcpropertyllc.com
FRONTEND_BASE_URL=https://www.lrcpropertyllc.com
ENFORCE_CANONICAL_HOST=true
REDIRECT_TARGET_PATH=/#paywall
LOG_REQUESTS=true
NODE_ENV=production

# Financial actions remain disabled until both flags are explicitly set true.
PAYMENTS_ENABLED=false
OWNER_APPROVED_PAYMENTS=false
ALLOW_TEST_KEYS=false

# Stripe and database server-side values.
# Leave blank in source control; set real values only as host environment secrets after payment enablement is approved.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
DATABASE_URL=
EXPECTED_PAYMENT_AMOUNT=1200
EXPECTED_CURRENCY=usd
